{
  "name": "@headlessoracle/verify",
  "version": "1.0.1",
  "description": "Verify cryptographically signed market-state receipts from Headless Oracle",
  "keywords": [
    "headless-oracle",
    "market-status",
    "ed25519",
    "verification",
    "ai-agents"
  ],
  "homepage": "https://headlessoracle.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/LembaGang/headless-oracle-verify.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
